# AgentForge Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# Anthropic API
ANTHROPIC_API_KEY=

# Claude Code CLI path (if not on PATH)
CLAUDE_CODE_PATH=

# Target directory for generated scaffolds
SCAFFOLD_OUTPUT_DIR=

# claude-mem integration (optional)
CLAUDE_MEM_ENDPOINT=

# Logging level: debug | info | warn | error
LOG_LEVEL=info
